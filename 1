    def set_busy(self, busy: bool):
        self.is_running = busy
        cursor = "watch" if busy else ""
        self.root.configure(cursor=cursor)

    def run_background(self, job, done, status_var: tk.StringVar, running_text: str):
        if self.is_running:
            messagebox.showwarning("提醒", "已有任務執行中，請等目前任務完成。")
            return
        self.set_busy(True)
        status_var.set(running_text)

        def worker():
            try:
                result = job()
                self.root.after(0, lambda: finish(result, None))
            except Exception as exc:
                self.root.after(0, lambda: finish(None, exc))

        def finish(result, exc):
            self.set_busy(False)
            if exc is not None:
                status_var.set(f"執行失敗：{exc}")
                messagebox.showerror("錯誤", f"執行失敗：\n{exc}")
                return
            done(result)

        threading.Thread(target=worker, daemon=True).start()

    def run_market_pr(self):
        try:
            end_date = self.pr_date_selector.get()
        except ValueError as exc:
            messagebox.showwarning("提醒", str(exc))
            return

        error = validate_market_pr_end_date(end_date)
        if error:
            messagebox.showwarning("提醒", error)
            return

        def job():
            return self.analyzer.run_market_pr(end_date)

        def done(result: dict):
            self.market_status_var.set(result.get("message", ""))
            for item in self.market_tree.get_children():
                self.market_tree.delete(item)

            self.last_score_csv = None
            self.last_strong_csv = None

            if not result.get("ok"):
                return

            self.last_score_csv = script_path(result.get("score_csv", ""))
            self.last_strong_csv = script_path(result.get("strong_csv", ""))
            summary = f"完成：可計算股票數 {result.get('total_count')}，PR > 80 強勢股 {result.get('strong_count')} 檔。"
            self.market_status_var.set(summary)

            for row in result.get("rows", []):
                self.market_tree.insert("", "end", values=(
                    row.get("rank", ""),
                    row.get("code", ""),
                    row.get("name", ""),
                    f"{float(row.get('weighted_pr_score', 0)):.2f}",
                    format_return(row.get("q1_return_recent")),
                    format_return(row.get("q2_return")),
                    format_return(row.get("q3_return")),
                    format_return(row.get("q4_return_oldest")),
                ))

        self.run_background(job, done, self.market_status_var, "執行中，第一次需抓取較多資料，請耐心等候...")

    def get_selected_market_code(self) -> Optional[str]:
        selected = self.market_tree.selection()
        if not selected:
            return None
        values = self.market_tree.item(selected[0], "values")
        if len(values) >= 2:
            return str(values[1]).strip()
        return None

    def run_selected_market_backtest(self):
        code = self.get_selected_market_code()
        if not code:
            messagebox.showwarning("提醒", "請先在市場 PR 表格中選取一檔股票。")
            return

        try:
            buy_date = self.pr_date_selector.get()
        except ValueError as exc:
            messagebox.showwarning("提醒", str(exc))
            return

        try:
            stop_loss = parse_optional_float(self.market_stop_loss_var.get())
            take_profit = parse_optional_float(self.market_take_profit_var.get())
        except ValueError:
            messagebox.showerror("錯誤", "停損或停利百分比格式錯誤。")
            return

        self.market_backtest_text.delete("1.0", tk.END)
        self.market_backtest_text.insert(tk.END, f"{code} 回測中，請稍候...\n")

        def job():
            return self.analyzer.run_buy_date_window(code, buy_date, stop_loss, take_profit)

        def done(result: dict):
            self.market_backtest_text.delete("1.0", tk.END)
            self.market_backtest_text.insert(tk.END, result.get("message", ""))
            if result.get("ok"):
                image_path = script_path(result.get("image", ""))
                self.last_market_backtest_image = image_path
                self.set_image_preview(self.market_backtest_image_label, image_path, max_width=520, max_height=210)
            else:
                self.last_market_backtest_image = None
                self.market_backtest_image_label.configure(image="", text="回測未產生圖表")
                self.market_backtest_image_label.image = None

        self.run_background(job, done, self.market_status_var, f"{code} 執行停損停利回測中...")

    def run_chart(self):
        symbol = self.symbol_var.get().strip()
        try:
            start_date = self.chart_start_selector.get()
            end_date = self.chart_end_selector.get()
        except ValueError as exc:
            messagebox.showwarning("提醒", str(exc))
            return

        if not symbol:
            messagebox.showwarning("提醒", "請輸入股票代號。")
            return
        if pd.to_datetime(start_date) >= pd.to_datetime(end_date):
            messagebox.showwarning("提醒", "開始日期必須早於結束日期。")
            return
        if pd.to_datetime(end_date).normalize() > pd.Timestamp.today().normalize():
            messagebox.showwarning("提醒", "結束日期不能晚於今天。")
            return

        def job():
            return self.analyzer.run_visualization(symbol, start_date, end_date)

        def done(result: dict):
            self.chart_status_var.set(result.get("message", ""))
            if result.get("ok"):
                image_path = script_path(result.get("image", ""))
                self.last_chart_image = image_path
                self.set_image_preview(self.chart_image_label, image_path, max_width=1060, max_height=570)
            else:
                self.last_chart_image = None
                self.chart_image_label.configure(image="", text="圖表未產生")
                self.chart_image_label.image = None

        self.run_background(job, done, self.chart_status_var, "產生圖表中，第一次需補抓資料，請耐心等候...")

    def set_image_preview(self, label: ttk.Label, image_path: str, max_width: int, max_height: int):
        if not image_path or not os.path.exists(image_path):
            label.configure(image="", text=f"找不到圖檔：{image_path}")
            label.image = None
            return
        try:
            img = tk.PhotoImage(file=image_path)
            scale = max(1, math.ceil(img.width() / max_width), math.ceil(img.height() / max_height))
            if scale > 1:
                img = img.subsample(scale, scale)
            label.configure(image=img, text="")
            label.image = img
        except Exception as exc:
            label.configure(image="", text=f"圖檔已產生：\n{image_path}\n\n無法預覽：{exc}")
            label.image = None


